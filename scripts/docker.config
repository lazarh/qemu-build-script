# Docker requirements: storage, networking, cgroups
# Apply with: scripts/kconfig/merge_config.sh -m .config scripts/docker.config

# OverlayFS (container image layers)
CONFIG_OVERLAY_FS=y

# Netfilter / iptables (container networking + NAT)
CONFIG_NETFILTER=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_BRIDGE=y

# Control Groups (resource isolation)
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_SCHED=y
