# Docker requirements: storage, networking, cgroups
# Apply with: scripts/config --enable <option> + make olddefconfig

# OverlayFS (container image layers)
CONFIG_OVERLAY_FS=y

# Netfilter / iptables (container networking + NAT)
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XTABLES_LEGACY=y
CONFIG_NETFILTER_XT_TARGET_MASQUERADE=y
CONFIG_IP_NF_IPTABLES_LEGACY=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_BRIDGE=y

# Control Groups (resource isolation)
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_SCHED=y
